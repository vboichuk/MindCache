<resources>
    <!-- Base application theme. -->
    <style name="Theme.MindCache" parent="Theme.MaterialComponents.Light.NoActionBar">

        <item name="android:textColor">@color/black</item>
        <item name="android:colorBackground">@color/white</item>

        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primaryVariant</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_500</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorSurface">@color/surface_color</item>
        <item name="colorOnSurface">@color/onSurface</item>

        <item name="android:statusBarColor">@color/action_bar</item>

        <item name="toolbarStyle">@style/ActionBarStyle</item>
        <item name="drawerArrowStyle">@style/BackArrowStyle</item>

        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.MaterialComponents.BottomSheetDialog</item>


    </style>

    <!-- Стиль для ActionBar/Toolbar -->
    <style name="ActionBarStyle" parent="Widget.MaterialComponents.Toolbar.Surface">
        <item name="android:background">@color/action_bar</item>
        <item name="titleTextColor">@color/on_action_bar</item>
    </style>

    <style name="BackArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="spinBars">true</item>
        <item name="color">@color/on_action_bar</item> <!-- Arrow Color -->
    </style>

</resources>